import os
import cv2
import tkinter as tk
from tkinter import ttk, messagebox, filedialog
from PIL import Image, ImageTk
from datetime import datetime

# Optional Pi Camera support
PICAMERA2_AVAILABLE = False
try:
    from picamera2 import Picamera2
    PICAMERA2_AVAILABLE = True
except ImportError:
    PICAMERA2_AVAILABLE = False

# =========================
# SETTINGS
# =========================
DEFAULT_SAVE_FOLDER = os.path.join(os.getcwd(), "captured_images")
PREVIEW_WIDTH = 640
PREVIEW_HEIGHT = 480
WINDOW_TITLE = "Camera Capture GUI"

os.makedirs(DEFAULT_SAVE_FOLDER, exist_ok=True)


class CameraApp:
    def __init__(self, root):
        self.root = root
        self.root.title(WINDOW_TITLE)
        self.root.geometry("900x760")
        self.root.resizable(False, False)

        self.cap = None
        self.picam2 = None
        self.current_camera_type = None
        self.current_camera_index = None
        self.preview_running = False
        self.preview_job = None
        self.last_frame_bgr = None

        self.available_cameras = []
        self.camera_var = tk.StringVar()
        self.status_var = tk.StringVar(value="Scanning for cameras...")
        self.save_folder = DEFAULT_SAVE_FOLDER

        self.build_gui()
        self.refresh_camera_list()

        self.root.protocol("WM_DELETE_WINDOW", self.on_close)

    def build_gui(self):
        title_label = tk.Label(
            self.root,
            text="Camera Capture with Live Preview",
            font=("Arial", 18, "bold")
        )
        title_label.pack(pady=12)

        top_frame = tk.Frame(self.root)
        top_frame.pack(pady=8)

        tk.Label(top_frame, text="Select Camera:", font=("Arial", 11)).pack(side=tk.LEFT, padx=5)

        self.camera_dropdown = ttk.Combobox(
            top_frame,
            textvariable=self.camera_var,
            state="readonly",
            width=30
        )
        self.camera_dropdown.pack(side=tk.LEFT, padx=5)

        connect_button = tk.Button(
            top_frame,
            text="Connect",
            command=self.start_selected_camera,
            width=12,
            font=("Arial", 10)
        )
        connect_button.pack(side=tk.LEFT, padx=5)

        refresh_button = tk.Button(
            top_frame,
            text="Refresh Cameras",
            command=self.refresh_camera_list,
            width=14,
            font=("Arial", 10)
        )
        refresh_button.pack(side=tk.LEFT, padx=5)

        preview_frame = tk.Frame(self.root, bd=2, relief=tk.GROOVE)
        preview_frame.pack(pady=15)

        self.preview_label = tk.Label(
            preview_frame,
            text="No camera preview",
            bg="black",
            fg="white",
            width=PREVIEW_WIDTH,
            height=PREVIEW_HEIGHT
        )
        self.preview_label.pack()

        button_frame = tk.Frame(self.root)
        button_frame.pack(pady=12)

        capture_button = tk.Button(
            button_frame,
            text="Capture Image",
            command=self.capture_image,
            bg="#2e8b57",
            fg="white",
            font=("Arial", 12, "bold"),
            width=16,
            height=2
        )
        capture_button.pack(side=tk.LEFT, padx=10)

        folder_button = tk.Button(
            button_frame,
            text="Select Save Folder",
            command=self.choose_folder,
            font=("Arial", 12),
            width=16,
            height=2
        )
        folder_button.pack(side=tk.LEFT, padx=10)

        stop_button = tk.Button(
            button_frame,
            text="Stop Camera",
            command=self.stop_camera,
            font=("Arial", 12),
            width=16,
            height=2
        )
        stop_button.pack(side=tk.LEFT, padx=10)

        self.status_label = tk.Label(
            self.root,
            textvariable=self.status_var,
            font=("Arial", 10),
            fg="blue"
        )
        self.status_label.pack(pady=10)

        self.folder_label = tk.Label(
            self.root,
            text=f"Save Folder: {self.save_folder}",
            font=("Arial", 10),
            fg="gray30",
            wraplength=850,
            justify="center"
        )
        self.folder_label.pack(pady=4)

        shortcut_label = tk.Label(
            self.root,
            text="Tip: Press Spacebar to capture an image after connecting a camera.",
            font=("Arial", 9),
            fg="gray40"
        )
        shortcut_label.pack(pady=2)

        self.root.bind("<space>", lambda event: self.capture_image())

    def detect_cameras(self):
        cameras = []

        if PICAMERA2_AVAILABLE:
            try:
                test_picam = Picamera2()
                test_picam.close()
                cameras.append({
                    "type": "pi",
                    "index": None,
                    "label": "Raspberry Pi Camera"
                })
            except Exception:
                pass

        for i in range(5):
            cap = cv2.VideoCapture(i)
            if cap.isOpened():
                ret, _ = cap.read()
                if ret:
                    cameras.append({
                        "type": "usb",
                        "index": i,
                        "label": f"USB Camera {i}"
                    })
            cap.release()

        return cameras

    def refresh_camera_list(self):
        self.stop_camera()
        self.available_cameras = self.detect_cameras()

        labels = [cam["label"] for cam in self.available_cameras]
        self.camera_dropdown["values"] = labels

        if labels:
            self.camera_var.set(labels[0])
            self.status_var.set("Cameras detected. Select one and click Connect.")
        else:
            self.camera_var.set("")
            self.status_var.set("No cameras found.")
            self.preview_label.config(image="", text="No camera preview", bg="black")

    def get_selected_camera(self):
        selected_label = self.camera_var.get()
        for cam in self.available_cameras:
            if cam["label"] == selected_label:
                return cam
        return None

    def choose_folder(self):
        folder = filedialog.askdirectory(initialdir=self.save_folder)
        if folder:
            self.save_folder = folder
            self.folder_label.config(text=f"Save Folder: {self.save_folder}")
            self.status_var.set(f"Save folder set to: {self.save_folder}")

    def start_selected_camera(self):
        selected = self.get_selected_camera()
        if not selected:
            messagebox.showwarning("No Camera", "Please select a camera first.")
            return

        self.stop_camera()

        try:
            if selected["type"] == "pi":
                self.picam2 = Picamera2()
                config = self.picam2.create_preview_configuration(
                    main={"size": (PREVIEW_WIDTH, PREVIEW_HEIGHT)}
                )
                self.picam2.configure(config)
                self.picam2.start()
                self.current_camera_type = "pi"
                self.current_camera_index = None

            elif selected["type"] == "usb":
                self.cap = cv2.VideoCapture(selected["index"])
                if not self.cap.isOpened():
                    raise RuntimeError(f"Could not open USB Camera {selected['index']}")

                self.cap.set(cv2.CAP_PROP_FRAME_WIDTH, PREVIEW_WIDTH)
                self.cap.set(cv2.CAP_PROP_FRAME_HEIGHT, PREVIEW_HEIGHT)

                self.current_camera_type = "usb"
                self.current_camera_index = selected["index"]

            self.preview_running = True
            self.status_var.set(f"Connected to {selected['label']}")
            self.update_preview()

        except Exception as e:
            self.status_var.set("Failed to connect to camera.")
            messagebox.showerror("Camera Error", str(e))

    def update_preview(self):
        if not self.preview_running:
            return

        frame = None

        try:
            if self.current_camera_type == "usb" and self.cap is not None:
                ret, frame = self.cap.read()
                if not ret:
                    frame = None

            elif self.current_camera_type == "pi" and self.picam2 is not None:
                frame = self.picam2.capture_array()
                if frame is not None:
                    if len(frame.shape) == 3 and frame.shape[2] == 4:
                        frame = cv2.cvtColor(frame, cv2.COLOR_RGBA2BGR)
                    elif len(frame.shape) == 3 and frame.shape[2] == 3:
                        frame = cv2.cvtColor(frame, cv2.COLOR_RGB2BGR)

            if frame is not None:
                self.last_frame_bgr = frame.copy()

                rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                img = Image.fromarray(rgb_frame)
                img = img.resize((PREVIEW_WIDTH, PREVIEW_HEIGHT))
                imgtk = ImageTk.PhotoImage(image=img)

                self.preview_label.imgtk = imgtk
                self.preview_label.configure(image=imgtk, text="")

        except Exception as e:
            self.status_var.set(f"Preview error: {e}")

        self.preview_job = self.root.after(30, self.update_preview)

    def capture_image(self):
        if self.last_frame_bgr is None:
            messagebox.showwarning("No Image", "No preview frame available to save.")
            return

        try:
            os.makedirs(self.save_folder, exist_ok=True)
            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            filename = os.path.join(self.save_folder, f"image_{timestamp}.jpg")

            success = cv2.imwrite(filename, self.last_frame_bgr)
            if not success:
                raise RuntimeError("OpenCV could not save the image.")

            self.status_var.set(f"Saved image: {filename}")
            print(f"Saved image: {filename}")

        except Exception as e:
            messagebox.showerror("Save Error", str(e))

    def stop_camera(self):
        self.preview_running = False

        if self.preview_job is not None:
            try:
                self.root.after_cancel(self.preview_job)
            except Exception:
                pass
            self.preview_job = None

        if self.cap is not None:
            self.cap.release()
            self.cap = None

        if self.picam2 is not None:
            try:
                self.picam2.stop()
            except Exception:
                pass
            try:
                self.picam2.close()
            except Exception:
                pass
            self.picam2 = None

        self.current_camera_type = None
        self.current_camera_index = None
        self.last_frame_bgr = None

        self.preview_label.config(image="", text="No camera preview", bg="black")

    def on_close(self):
        self.stop_camera()
        self.root.destroy()


if __name__ == "__main__":
    root = tk.Tk()
    app = CameraApp(root)
    root.mainloop()